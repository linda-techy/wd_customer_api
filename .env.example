# ============================================================
# WD Customer API — Environment Variables
# Copy this file to .env (local) and set real values.
# NEVER commit .env or any file containing real secrets.
# ============================================================

# --- Spring Profile ---
# Options: local | staging | production
SPRING_PROFILES_ACTIVE=local

# --- Database (PostgreSQL) ---
# Local example:  jdbc:postgresql://localhost:5432/wd_customer_local
# Staging:        jdbc:postgresql://HOST:5432/wd_customer_staging
# Production:     jdbc:postgresql://HOST:5432/wd_customer_prod
DB_URL=jdbc:postgresql://localhost:5432/wd_customer_local
DB_USERNAME=postgres
DB_PASSWORD=change_me

# --- JWT Secret (HS256) ---
# Generate with: openssl rand -hex 32
# Must be DIFFERENT from the portal API secret.
# Local default is set in application-local.yml — override here for dev if needed.
JWT_SECRET=generate_a_64_char_hex_string_here

# --- SMTP (Hostinger) ---
MAIL_USERNAME=info@walldotbuilders.com
MAIL_PASSWORD=change_me

# --- CORS ---
# Comma-separated list of allowed origins
# Local:       http://localhost:3002,http://127.0.0.1:3002
# Production:  https://app.walldotbuilders.com
CORS_ALLOWED_ORIGINS=http://localhost:3002

# --- File Storage ---
# Must match the portal API storage path so files are shared
# Local (Windows):   N:\Projects\wd projects git\storage
# Production:        /home/ftpuser/var/www/app/walldotbuilders/storage
FILE_UPLOAD_DIR=./storage
STORAGE_BASE_PATH=./storage

# --- Swagger UI ---
# Enable ONLY in local/staging — never in production
SWAGGER_ENABLED=false

# --- Customer Portal Base URL (for password reset email links) ---
# Local:       http://localhost:3002
# Production:  https://app.walldotbuilders.com
CUSTOMER_PORTAL_BASE_URL=http://localhost:3002
